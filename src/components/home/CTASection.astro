---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
---

<Section
  id="contact"
  class="py-20"
>
  <Container>

    <div class="comic-panel cta-panel">

      <span class="comic-label">
        FINAL PANEL
      </span>

      <h2>
        Let's Build Something Amazing.
      </h2>

      <p>
        Whether it's a CRM platform, an AI-powered application,
        or a modern web experience, I'd love to hear about your idea.
      </p>

      <Button
        href="/contact"
        variant="primary"
      >
        Contact Me
      </Button>

    </div>

  </Container>
</Section>